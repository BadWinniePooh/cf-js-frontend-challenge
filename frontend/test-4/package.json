{
  "name": "cfb-test-4",
  "version": "1.0.0",
  "description": "T-4: IndexedDB store contract + component tests for session-store, cfb-session-store, cfb-session-loader, cfb-board-orchestrator",
  "type": "module",
  "scripts": {
    "test": "npm run test:store:fake && npm run test:store:real",
    "test:store:real": "web-test-runner test/*.contract.test.js --config test/web-test-runner.store-real.config.mjs",
    "test:store:fake": "web-test-runner --node-resolve --config test/web-test-runner.config.mjs",
    "test:watch": "web-test-runner \"test/**/*.test.js\" --node-resolve --watch --config test/web-test-runner.config.mjs",
    "test:specific": "web-test-runner --files=test/**/*${PATTERN:-*}*.test.js --node-resolve --config test/web-test-runner.config.mjs"
  },
  "devDependencies": {
    "@web/dev-server-import-maps": "^0.2.1",
    "@web/test-runner": "^0.19.0",
    "chai": "^5.2.0",
    "sinon": "^21.0.3",
    "sinon-chai": "^4.0.1"
  }
}
